<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Reactive Planet</title>
    <!-- Dark fill before JS/CSS bundle runs (avoids white flash / all-white if bundle fails) -->
    <style>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        background: #050505;
      }
      #app,
      #pixi-container {
        width: 100%;
        min-height: 100vh;
        background: #050505;
      }
      #pixi-container canvas {
        display: block;
        vertical-align: top;
      }
    </style>
</head>

<body>
    <div id="app">
        <div id="pixi-container"></div>
    </div>
</body>
</html>
